doctype html
html(lang="pt")
    head
        title Login - TwitterClone
        // Vamos usar Bootstrap por CDN para ficar bonito rápido
        link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    body
        .container.mt-5
            h1 Login
            form(method="post") 
                input.form-control.mb-3(type="text", name="logUsername", placeholder="Username ou Email", required="")
                input.form-control.mb-3(type="password", name="logPassword", placeholder="Password", required="")
                button.btn.btn-primary(type="submit") Entrar