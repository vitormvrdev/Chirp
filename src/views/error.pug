extends layouts/main-layout.pug

block content
    .flex.flex-col.items-center.justify-center.py-20
        .text-8xl.text-gray-300.mb-4 #{statusCode || 500}
        h1.text-2xl.font-bold.text-gray-900.mb-2 Oops!
        p.text-gray-500.text-center.max-w-md #{message || 'Algo correu mal.'}
        a.mt-6.bg-blue-500.text-white.px-6.py-2.rounded-full.font-bold(href="/", class="hover:bg-blue-600") Voltar ao início
