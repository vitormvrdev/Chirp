extends layouts/main-layout.pug

block content
    // --- CAIXA DE CRIAÇÃO DE TWEET ---
    .p-4.border-b.border-gray-border
        .flex
            // Foto do utilizador logado (Placeholder ou real se tiveres)
            .mr-4
                img(src=userLoggedIn.profilePic, alt="User", class="w-12 h-12 rounded-full bg-gray-200")
            
            // Área de texto
            .w-full
                textarea#postTextarea.w-full.border-none.resize-none.text-lg.outline-none.placeholder-gray-500(placeholder="O que está a acontecer?!", rows="2")
                
                .flex.justify-end.items-center.mt-2
                    button#submitPostButton.bg-blue-500.text-white.px-4.py-2.rounded-full.font-bold.opacity-50.cursor-not-allowed(disabled) Tweetar

    // --- AQUI VÃO APARECER OS POSTS ---
    .postsContainer