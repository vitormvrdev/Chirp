extends layouts/main-layout.pug

block content
    // Create Post Box
    .p-4.border-b.border-gray-border
        .flex
            // User Avatar
            .mr-4
                img(src=userLoggedIn.profilePic || "/images/profile_pic.png", alt="User", class="w-12 h-12 rounded-full bg-gray-200 object-cover")

            // Post Form
            .w-full
                textarea#postTextarea.w-full.border-none.resize-none.text-lg.outline-none.placeholder-gray-500(
                    placeholder="O que está a acontecer?!"
                    rows="2"
                    maxlength="280"
                )

                // Image Preview
                #imagePreview.hidden.mt-3.relative
                    img.rounded-xl.max-h-60.object-cover
                    button#removeImage.absolute.top-2.right-2.bg-gray-900.bg-opacity-75.text-white.rounded-full.w-8.h-8(class="hover:bg-opacity-100")
                        i.fa-solid.fa-xmark

                // Actions Bar
                .flex.justify-between.items-center.mt-3.pt-3.border-t.border-gray-100
                    .flex.items-center.space-x-2
                        // Image Upload
                        label.cursor-pointer.p-2.rounded-full.text-blue-500(class="hover:bg-blue-50")
                            i.fa-regular.fa-image.text-xl
                            input#postImage.hidden(type="file" accept="image/*")

                        // Character Counter
                        span#charCounter.text-gray-400.text-sm 280

                    button#submitPostButton.bg-blue-500.text-white.px-5.py-2.rounded-full.font-bold.opacity-50.cursor-not-allowed(
                        disabled
                        class="hover:bg-blue-600 disabled:hover:bg-blue-500"
                    ) Tweetar

    // Posts Feed
    .postsContainer
        // Loading indicator
        .flex.justify-center.py-8
            i.fa-solid.fa-spinner.fa-spin.text-2xl.text-blue-500

    script(src="/js/feed.js")
