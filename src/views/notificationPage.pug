extends layouts/main-layout.pug

block content
    .flex.flex-col
        if notifications.length === 0
            .flex.flex-col.items-center.justify-center.py-16
                i.fa-regular.fa-bell.text-6xl.text-gray-300.mb-4
                span.text-gray-500.text-lg Sem notificações
                span.text-gray-400.text-sm.mt-1 As tuas notificações aparecerão aqui

        else
            each notification in notifications
                - var userFrom = notification.userFrom;
                - var text = '';
                - var icon = '';
                - var link = '/';

                case notification.notificationType
                    when 'postLike'
                        - text = 'gostou do teu post';
                        - icon = 'fa-heart text-red-500';
                        - link = `/profile/${userFrom.userhandle}`;
                    when 'retweet'
                        - text = 'repostou o teu post';
                        - icon = 'fa-retweet text-green-500';
                        - link = `/profile/${userFrom.userhandle}`;
                    when 'follow'
                        - text = 'começou a seguir-te';
                        - icon = 'fa-user-plus text-blue-500';
                        - link = `/profile/${userFrom.userhandle}`;
                    when 'comment'
                        - text = 'comentou o teu post';
                        - icon = 'fa-comment text-blue-500';
                        - link = `/profile/${userFrom.userhandle}`;
                    default
                        - text = 'interagiu contigo';
                        - icon = 'fa-bell text-gray-500';

                a.flex.p-4.border-b.border-gray-border(href=link, class="hover:bg-gray-50 " + (!notification.opened ? 'bg-blue-50' : ''))
                    .flex-shrink-0.mr-4.w-10.text-center
                        i.fa-solid.text-2xl(class=icon)
                    .flex.flex-col.flex-grow
                        .flex.items-center.mb-1
                            img.w-8.h-8.rounded-full.mr-2.object-cover(src=userFrom.profilePic || "/images/profile_pic.png")
                            span.font-bold.mr-1 #{userFrom.firstName} #{userFrom.lastName}
                            span.text-gray-500 #{text}
                        span.text-gray-400.text-xs #{timeDifference(notification.createdAt)}

    script.
        function timeDifference(date) {
            const msPerMinute = 60 * 1000;
            const msPerHour = msPerMinute * 60;
            const msPerDay = msPerHour * 24;
            const elapsed = new Date() - new Date(date);

            if (elapsed < msPerMinute) return 'agora mesmo';
            if (elapsed < msPerHour) return Math.round(elapsed / msPerMinute) + ' min';
            if (elapsed < msPerDay) return Math.round(elapsed / msPerHour) + ' h';
            return Math.round(elapsed / msPerDay) + ' d';
        }
