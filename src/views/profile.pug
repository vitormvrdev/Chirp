extends layouts/main-layout.pug

block content
    if !profileUser
        .flex.flex-col.items-center.justify-center.py-20
            i.fa-solid.fa-user-slash.text-6xl.text-gray-300.mb-4
            span.text-gray-500 Utilizador não encontrado.
    else
        script.
            var profileUserId = '!{profileUser._id}';

        // Profile Header
        .flex.flex-col.border-b.border-gray-border

            // Cover Photo
            .h-48.bg-gradient-to-r.from-blue-400.to-blue-600.relative
                // Profile Picture
                .absolute.-bottom-16.left-4
                    .relative
                        img(src=profileUser.profilePic || "/images/profile_pic.png", alt="Profile Pic").w-32.h-32.rounded-full.border-4.border-white.bg-white.object-cover
                        if isOwnProfile
                            label.absolute.bottom-0.right-0.bg-blue-500.rounded-full.p-2.cursor-pointer(class="hover:bg-blue-600")
                                i.fa-solid.fa-camera.text-white.text-sm
                                input#profilePicInput.hidden(type="file" accept="image/*")

            // Profile Info
            .pt-16.px-4.pb-4.flex.flex-col

                // Action Buttons
                .flex.justify-end.mb-2.space-x-2
                    if !isOwnProfile
                        a.border.border-blue-500.text-blue-500.font-bold.px-4.py-2.rounded-full(href=`/messages/${profileUser._id}`, class="hover:bg-blue-50")
                            i.fa-regular.fa-envelope

                        if isFollowing
                            button#followButton.px-4.py-2.rounded-full.font-bold.bg-gray-200.text-gray-800(
                                data-user-id=profileUser._id
                                data-following="true"
                                class="hover:bg-red-100 hover:text-red-500"
                            ) A seguir
                        else
                            button#followButton.bg-blue-500.text-white.px-4.py-2.rounded-full.font-bold(
                                data-user-id=profileUser._id
                                data-following="false"
                                class="hover:bg-blue-600"
                            ) Seguir
                    else
                        a.border.border-gray-300.text-gray-900.font-bold.px-4.py-2.rounded-full(href="/profile/settings", class="hover:bg-gray-100") Editar Perfil

                // Name and Handle
                span.font-bold.text-xl.text-gray-900 #{profileUser.firstName} #{profileUser.lastName}
                span.text-gray-500 @#{profileUser.userhandle}

                // Bio placeholder
                if profileUser.bio
                    p.text-gray-800.mt-2 #{profileUser.bio}

                // Join Date
                span.text-gray-500.mt-3.text-sm
                    i.fa-regular.fa-calendar.mr-2
                    | Aderiu em #{new Date(profileUser.createdAt).toLocaleDateString('pt-PT', { month: 'long', year: 'numeric' })}

                // Followers/Following
                .flex.mt-3.space-x-4
                    a(href=`/profile/${profileUser.userhandle}/following`, class="hover:underline text-gray-500")
                        span.font-bold.text-gray-900.mr-1 #{profileUser.following ? profileUser.following.length : 0}
                        | A seguir
                    a(href=`/profile/${profileUser.userhandle}/followers`, class="hover:underline text-gray-500")
                        span#followerCount.font-bold.text-gray-900.mr-1 #{profileUser.followers ? profileUser.followers.length : 0}
                        | Seguidores

        // Tabs
        .flex.border-b.border-gray-border
            a.flex-1.text-center.p-4.font-bold.text-blue-500.border-b-4.border-blue-500.cursor-pointer Posts
            a.flex-1.text-center.p-4.font-medium.text-gray-500.cursor-pointer(class="hover:bg-gray-50") Respostas
            a.flex-1.text-center.p-4.font-medium.text-gray-500.cursor-pointer(class="hover:bg-gray-50") Gostos

        // Posts Container
        .postsContainer

        // Profile Pic Upload Script
        script.
            $('#profilePicInput').change(function() {
                const file = this.files[0];
                if (!file) return;

                const formData = new FormData();
                formData.append('image', file);

                $.ajax({
                    url: '/api/upload/profile',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: (res) => {
                        $('img[alt="Profile Pic"]').attr('src', res.imageUrl);
                        showToast('Foto de perfil atualizada', 'success');
                    },
                    error: () => showToast('Erro ao atualizar foto', 'error')
                });
            });

        script(src="/js/profile.js")
